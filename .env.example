EXTEND_ESLINT=true

# Local development - keep API base empty so Vite proxy serves /api/* via localhost.
REACT_APP_API_BASE_URL=
REACT_APP_PROXY_TARGET=https://deverp.narayanseva.org
VITE_API_BASE_URL=
VITE_PROXY_TARGET=https://deverp.narayanseva.org

# Production/Staging on S3/CloudFront - use absolute API host.
# REACT_APP_API_BASE_URL=https://deverp.narayanseva.org
# VITE_API_BASE_URL=https://deverp.narayanseva.org
